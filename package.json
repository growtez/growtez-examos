{
  "name": "growtez-examos",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=web-panel --filter=landing-page",
    "dev:all": "turbo run dev",
    "dev:desktop": "turbo run dev --filter=desktop-app",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "2.0.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.14.4"
}
